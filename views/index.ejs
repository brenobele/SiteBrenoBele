                <div class="profile-card">
                  <p class="profile-card-label">Perfil profissional</p>
                  <h2 class="profile-card-title">Breno S. Beletato</h2>
                  <p class="profile-card-text">
                    Desenvolvimento orientado por clareza, manutenção e apresentação visual consistente.
                  </p>

                  <div class="profile-stats">
                    <div class="stat-item">
                      <strong>Foco</strong>
                      <span>Eficiência com elegância visual</span>
                    </div>
                    <div class="stat-item">
                      <strong>Estilo</strong>
                      <span>Interfaces sóbrias e comunicação direta</span>
                    </div>
                    <div class="stat-item">
                      <strong>Objetivo</strong>
                      <span>Transformar requisitos em entregas confiáveis</span>
                    </div>
                  </div>
                </div>
              </aside>
            </div>
