    <section id="home" class="hero-custom section">
      <div class="container">
        <div class="hero-shell glass-panel">
          <div class="columns is-variable is-7 is-vcentered">
            <div class="column is-7-desktop">
              <div class="fade-in-up">
                <p class="section-eyebrow">Analista e Desenvolvedor de Sistemas</p>
                <h1 class="hero-title">
                  Soluções digitais com estética contida, arquitetura clara e foco em resultado.
                </h1>
