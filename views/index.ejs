                </p>

                <div class="hero-actions fade-in-up delay-1">
                  <a href="mailto:contato@brenobele.dev" class="btn-modern btn-primary">
                    <i class="fas fa-envelope btn-icon"></i> Entrar em contato
                  </a>
                  <a href="#especialidades" class="btn-modern btn-secondary">
