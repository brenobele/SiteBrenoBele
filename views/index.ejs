<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfólio de Breno S. Beletato - Analista e Desenvolvedor de Sistemas" />
  <title>Breno S. Beletato | Desenvolvedor</title>

  <!-- Google Fonts: Outfit for Display, Inter for Sans text -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@300;500;700;800&display=swap"
    rel="stylesheet">

  <!-- FontAwesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />

  <!-- Bulma 1.0.0 CSS Framework -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.0/css/bulma.min.css" />

  <!-- Custom Modern CSS -->
  <link rel="stylesheet" type="text/css" href="css/landing.css" />
  <link rel="icon" type="image/png" href="img/favicon.ico" sizes="32x32" />

  <!-- Microsoft Clarity Analytics -->
  <script type="text/javascript">
    (function (c, l, a, r, i, t, y) {
      c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };
      t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", "vq8o1q5npi");
  </script>
</head>

<body>

  <!-- Animated Background Blobs -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <!-- Navigation -->
  <nav class="navbar is-transparent" role="navigation" aria-label="main navigation">
    <div class="container">
      <div class="navbar-brand">
        <a class="navbar-item" href="/">
          <span style="font-family: 'Outfit'; font-weight: 800; font-size: 1.5rem;">
            Breno<span style="color: var(--accent-cyan);">Bele</span>
          </span>
        </a>

        <a role="button" class="navbar-burger burger" aria-label="menu" aria-expanded="false" data-target="navbarMenu">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </a>
      </div>

      <div id="navbarMenu" class="navbar-menu">
        <div class="navbar-end">
          <a class="navbar-item" href="#home">Home</a>
          <a class="navbar-item" href="https://github.com/brenobele" target="_blank">
            <span class="icon is-small" style="margin-right: 4px;"><i class="fab fa-github"></i></span> GitHub
          </a>
          <a class="navbar-item" href="https://linkedin.com/in/brenobele" target="_blank">
            <span class="icon is-small" style="margin-right: 4px;"><i class="fab fa-linkedin"></i></span> LinkedIn
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="home" class="hero-custom">
    <div class="container">
      <div class="columns is-vcentered">

        <!-- Text Content -->
        <div class="column is-6 px-5" style="padding-left: 2rem; padding-right: 2rem;">
          <div class="fade-in-up delay-1">
            <p class="is-size-6 has-text-weight-semibold"
              style="color: var(--accent-cyan); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem;">
              Bem-vindo!
            </p>
            <h1 class="hero-title">
              Olá, eu sou <br>
              <span class="gradient-text">Breno S. Beletato</span>
            </h1>
            <p class="hero-subtitle">
              Sou Analista e Desenvolvedor de Sistemas, focado em criar soluções eficientes, escaláveis e esteticamente
              modernas.
              Dedicado a construir a ponte entre tecnologia e resultados.
            </p>

            <div class="action-buttons fade-in-up delay-2">
              <a href="mailto:contato@brenobele.dev" class="btn-modern btn-primary">
                <i class="fas fa-envelope btn-icon"></i> Entrar em Contato
              </a>
            </div>

            <div class="social-links fade-in-up delay-3">
              <a href="https://github.com/brenobele" class="social-link" target="_blank" aria-label="GitHub"><i
                  class="fab fa-github"></i></a>
              <a href="https://linkedin.com/in/brenobele" class="social-link" target="_blank" aria-label="LinkedIn"><i
                  class="fab fa-linkedin-in"></i></a>
              <a href="mailto:contato@brenobele.dev" class="social-link" target="_blank" aria-label="Email"><i
                  class="fas fa-envelope"></i></a>
            </div>
          </div>
        </div>

        <!-- Abstract/Glass Visual Content -->
        <div class="column is-5 is-offset-1 mt-6 mobile-margin">
          <div class="glass-panel fade-in-up delay-2 px-5"
            style="padding: 2.5rem; padding-left: 2rem; padding-right: 2rem;">
            <div class="content">
              <h3 class="title is-4" style="color: var(--text-main);">📌 Resumo Acadêmico</h3>
              <ul style="list-style: none; margin-left: 0;">
                <li style="margin-bottom: 1.5rem; display: flex; align-items: flex-start;">
                  <span class="icon has-text-info mt-1 mr-3"><i class="fas fa-laptop-code"></i></span>
                  <div>
                    <strong style="color: var(--accent-cyan);">Análise e Desenvolvimento de Sistemas</strong><br>
                    <span class="is-size-7" style="color: var(--text-muted);">Graduação - FATEC de Presidente
                      Prudente</span>
                  </div>
                </li>
                <li style="display: flex; align-items: flex-start;">
                  <span class="icon has-text-info mt-1 mr-3"><i class="fas fa-network-wired"></i></span>
                  <div>
                    <strong style="color: var(--accent-purple);">Redes de Computadores e Comunicação</strong><br>
                    <span class="is-size-7" style="color: var(--text-muted);">Pós-Graduação - Universidade Estadual de
                      Londrina (UEL)</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer-modern">
    <div class="container">
      <div class="columns is-centered">
        <div class="column is-6 has-text-centered">
          <p class="mb-4">
            <span
              style="font-family: 'Outfit'; font-weight: 700; font-size: 1.2rem; margin-bottom: 1rem; display: block;">
              Breno<span style="color: var(--accent-cyan);">Bele</span>
            </span>
            Site construído com <a href="https://nodejs.org/" target="_blank">Node.js</a>, <a href="https://bulma.io"
              target="_blank">Bulma CSS</a>.
          </p>
          <p class="is-size-7">
            &copy; <span id="year">2026</span> Breno S. Beletato. Todos os direitos reservados.
          </p>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <script type="text/javascript" src="js/landing.js"></script>
  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</body>

</html>